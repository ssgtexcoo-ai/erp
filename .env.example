# Supabase — обязательно
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Telegram уведомления (опционально, для CI/агента)
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# Anthropic AI (для ИИ-декомпозиции)
ANTHROPIC_API_KEY=sk-ant-...

# Facebook Lead Ads (опционально, для автоимпорта лидов)
# FACEBOOK_VERIFY_TOKEN — любая случайная строка, ставится при настройке вебхука в Meta Dashboard
# FACEBOOK_PAGE_ACCESS_TOKEN — токен страницы из Meta Business Suite → Apps → Webhooks
FACEBOOK_VERIFY_TOKEN=your-random-verify-token
FACEBOOK_PAGE_ACCESS_TOKEN=your-page-access-token